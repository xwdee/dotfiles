{
	"aururl": "https://aur.archlinux.org",
	"aurrpcurl": "https://aur.archlinux.org/rpc?",
	"buildDir": "/var/cache/yay",
	"editor": "nano",
	"makepkgbin": "makepkg",
	"pacmanbin": "pacman",
	"pacmanconf": "/etc/pacman.conf",
	"redownload": "no",
	"answerupgrade": "none",
	"gitbin": "git",
	"gpgbin": "gpg",
	"sortby": "votes",
	"searchby": "name-desc",
	"removemake": "yes",
	"sudobin": "sudo",
	"requestsplitn": 150,
	"completionrefreshtime": 7,
	"maxconcurrentdownloads": 3,
	"sudoloop": true,
	"cleanAfter": false,
	"cleanmenu": false,
	"diffmenu": false,
	"editmenu": false,
	"combinedupgrade": true,
	"useask": false,
	"batchinstall": true,
	"separatesources": true,
	"doubleconfirm": false,
	"rebuild": "no"
}
